diff --git a/files/etc/init.d/audio-streamer b/files/etc/init.d/audio-streamer
new file mode 100755
index 00000000000..0a46c1a1ffb
--- /dev/null
+++ b/files/etc/init.d/audio-streamer
@@ -0,0 +1,42 @@
+#!/bin/sh /etc/rc.common
+
+START=90
+STOP=10
+
+USE_PROCD=1
+PROG=/usr/bin/gst-launch-1.0
+error() {
+	echo "${initscript}:" "$@" 1>&2
+}
+
+start_instance() {
+    local s="$1"
+
+    local enabled
+    config_get_bool enabled "$s" 'enabled' 0
+    [ "$enabled" -gt 0 ] || return
+
+    local host port
+    config_get host "$s" 'host'
+    config_get port "$s" 'port'
+
+    if [ -z "$host" ] || [ -z "$port" ]; then
+        error "Missing required 'host' or 'port' in config section '$s'"
+        return 1
+    fi
+
+    procd_open_instance
+    procd_set_param command "$PROG" -v alsasrc device=hw:0 ! \
+        "audio/x-raw,format=S16LE,channels=1,rate=8000" ! alawenc ! \
+        rtppcmapay ! udpsink host=${host} port=${port}
+    procd_close_instance
+}
+
+start_service() {
+    config_load 'audio-streamer'
+    config_foreach start_instance 'audio-streamer'
+}
+
+service_triggers() {
+	procd_add_reload_trigger 'audio-streamer'
+}
diff --git a/files/etc/init.d/ir-led b/files/etc/init.d/ir-led
new file mode 100755
index 00000000000..1994e8938c8
--- /dev/null
+++ b/files/etc/init.d/ir-led
@@ -0,0 +1,60 @@
+#!/bin/sh /etc/rc.common
+
+START=95
+STOP=10
+
+USE_PROCD=1
+
+start_service() {
+	config_load 'ir-led'
+	config_foreach start_instance 'ir-led'
+}
+
+start_instance() {
+	local section="$1"
+
+	local enabled sensor led
+	config_get_bool enabled "$section" 'enabled' 0
+	config_get sensor "$section" 'sensor'
+	config_get led "$section" 'led'
+
+	[ "$enabled" -gt 0 ] || return
+
+	# Validate GPIOs
+	[ -n "$sensor" ] || { echo "Missing 'sensor' GPIO in config"; return 1; }
+	[ -n "$led" ] || { echo "Missing 'led' GPIO in config"; return 1; }
+
+	# Export GPIOs if not already exported
+	[ -d /sys/class/gpio/gpio${sensor} ] || echo "$sensor" > /sys/class/gpio/export
+	[ -d /sys/class/gpio/gpio${led} ] || echo "$led" > /sys/class/gpio/export
+
+	# Set directions
+	echo "in" > /sys/class/gpio/gpio${sensor}/direction
+	echo "out" > /sys/class/gpio/gpio${led}/direction
+
+	# Start the passthrough loop
+	procd_open_instance
+	procd_set_param command /bin/sh -c "
+		while true; do
+			cat /sys/class/gpio/gpio${sensor}/value > /sys/class/gpio/gpio${led}/value
+			sleep 1
+		done"
+	procd_set_param respawn
+	procd_close_instance
+}
+
+stop_service() {
+	config_load 'ir-led'
+	config_foreach stop_instance 'ir-led'
+}
+
+stop_instance() {
+	local section="$1"
+
+	local sensor led
+	config_get sensor "$section" 'sensor'
+	config_get led "$section" 'led'
+
+	[ -d /sys/class/gpio/gpio${sensor} ] && echo "$sensor" > /sys/class/gpio/unexport
+	[ -d /sys/class/gpio/gpio${led} ] && echo "$led" > /sys/class/gpio/unexport
+}
